// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "amp-acp": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
  },
  "autosave": "on_window_change",
  "vim_mode": true,
  "ui_font_size": 14,
  "buffer_font_size": 11,
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "auto_install_extensions": {
    "html": true,
    "nix": true,
    "dockerfile": true,
    "docker-compose": false,
  },
}
